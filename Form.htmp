<!DOCTYPE html>
<html>
<head>
  <title>Registration Form</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<script>
// SIMPLE ACCESS PROTECTION
if(sessionStorage.getItem("paid") !== "true"){
  alert("Access denied! Please pay first.");
  window.location.href = "index.html";
}
</script>

<h1>📝 Enter Your Details</h1>

<form action="https://formspree.io/f/mvzwyjgg" method="POST">

  <input type="text" name="name" placeholder="Full Name" required>
  <br><br>

  <input type="tel" name="phone" placeholder="WhatsApp Number" required>
  <br><br>

  <button type="submit">Submit</button>

</form>

</body>
</html>
